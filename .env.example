# PostgreSQL
DATABASE_URL="postgres://pasted:pasted@127.0.0.1:5432/pasted"
DATABASE_POOL_SIZE="10"
BODY_SIZE_LIMIT="64M"

ORIGIN="http://localhost:5173"

# Docker host publication. Keep loopback unless a protected network requires otherwise.
APP_BIND_ADDRESS="127.0.0.1"
APP_PORT="3000"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"

# Optional comma-separated reverse proxy IP addresses or CIDR ranges.
# The origin must not be directly reachable by clients when this is set.
TRUSTED_PROXY_IPS=""

# Optional GitHub sign in
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
