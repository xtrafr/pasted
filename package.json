{
  "name": "pasted",
  "version": "1.0.0",
  "description": "Save links, notes, images, and selected links from WhatsApp exports in a private local library.",
  "main": "./out/main/index.js",
  "author": {
    "name": "xtrafr",
    "email": "xtr4@tutamail.com",
    "url": "https://github.com/xtrafr"
  },
  "homepage": "https://github.com/xtrafr/pasted",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xtrafr/pasted.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@hono/node-server": "^2.0.11",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tiptap/extension-code-block-lowlight": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.6.5",
    "@tiptap/pm": "^2.6.5",
    "@tiptap/react": "^2.6.5",
    "@tiptap/starter-kit": "^2.6.5",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "env-paths": "^2.2.1",
    "fuse.js": "^7.0.0",
    "hono": "^4.6.16",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.407.0",
    "muninn": "^0.23.0",
    "nbff-converter": "^1.1.2",
    "react-router-dom": "^6.24.1",
    "react-virtuoso": "^4.12.5",
    "sequelize": "^6.37.3",
    "sonner": "^1.5.0",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.19",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "postcss": "^8.4.39",
    "prettier": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
